{
  "buildCommand": "pnpm install && pnpm --filter @workspace/jabeen-jewels run build",
  "outputDirectory": "artifacts/jabeen-jewels/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!_next).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
